{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.example", ".nvmrc", "pnpm-workspace.yaml"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".svelte-kit/**", "build/**", "generated/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [],
      "outputs": []
    },
    "db:generate": {
      "outputs": ["generated/**"]
    }
  }
}
