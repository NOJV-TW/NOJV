# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nojv

# Auth
BETTER_AUTH_SECRET=dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:5173

# OAuth
GITHUB_CLIENT_ID=placeholder
GITHUB_CLIENT_SECRET=placeholder
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# Email
RESEND_API_KEY=placeholder
EMAIL_FROM_DOMAIN=example.com

# Redis
REDIS_URL=redis://localhost:6379

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Execution
EXECUTION_BACKEND=docker
SANDBOX_IMAGE=nojv-sandbox:local
SANDBOX_CPU_LIMIT=1
SANDBOX_MEMORY_MB=256
SANDBOX_PIDS_LIMIT=64

# Worker
PORT=8082
WORKER_CONCURRENCY=4
# WORKER_MODE: "all" (default), "judge" (sandbox only), "platform" (lifecycle/plagiarism only)
WORKER_MODE=all

# Web (Vite)
# Comma-separated hostnames allowed by Vite host check.
# Example: localhost,127.0.0.1,your.domain
# Use "*" to allow all hosts (not recommended outside local debugging).
ALLOWED_HOSTS=localhost,127.0.0.1,your.domain

# Kubernetes — only if EXECUTION_BACKEND=kubernetes
# K8S_NAMESPACE=nojv-sandbox
# K8S_CPU_REQUEST=500m
# K8S_CPU_LIMIT=1
# K8S_MEMORY_REQUEST=256Mi
# K8S_MEMORY_LIMIT=512Mi

# Object Storage (S3-compatible — Garage for local, GCS/R2/S3 for production)
# Local dev uses Garage (https://garagehq.deuxfleurs.fr/) via docker-compose.
# Run `./scripts/bootstrap-garage.sh` after `docker compose up -d garage` to
# provision the bucket + key, then paste the printed credentials below.
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_ACCESS_KEY=run-scripts/bootstrap-garage.sh-to-get-this
S3_SECRET_KEY=run-scripts/bootstrap-garage.sh-to-get-this
S3_BUCKET=nojv
# S3_PUBLIC_URL=https://cdn.example.com

# --- Grafana Cloud observability ---
# Get from https://grafana.com/orgs/<your-org>/stacks then "Send Metrics via OTLP"
# Leave empty to disable telemetry export (no-op SDK)
GRAFANA_OTLP_ENDPOINT=
GRAFANA_OTLP_INSTANCE_ID=
GRAFANA_OTLP_TOKEN=
# Optional: separate per-app service name override
OTEL_SERVICE_NAME_WEB=nojv-web
OTEL_SERVICE_NAME_WORKER=nojv-worker
# /metrics endpoint protection (random secret, web only)
METRICS_TOKEN=
