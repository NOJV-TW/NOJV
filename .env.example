# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nojv
# Max connections per Prisma pg pool (per process). Defaults to 10. In production
# this multiplies by Cloud Run maxScale (15): 15 × 10 = 150 connections, which
# must stay under Cloud SQL `max_connections` for the chosen tier (leave headroom
# for the worker pool + migrations). Lower it on small instances.
DB_POOL_MAX=10

# Destructive test database safety guard. Provision the dedicated databases and
# their durable safety markers with `pnpm test:db:provision` before running
# integration or E2E tests. Destructive tests ignore DATABASE_URL and require
# these two values to agree exactly.
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/nojv_test
NOJV_DESTRUCTIVE_TEST_DATABASE=nojv_test
# E2E uses a separate database. Override both values when running Playwright:
# TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/nojv_e2e_test
# NOJV_DESTRUCTIVE_TEST_DATABASE=nojv_e2e_test

# Auth
BETTER_AUTH_SECRET=local-dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:5173
# Seed admin account (required by db:seed / db:seed:prod / db:bootstrap-admin;
# production requires a password of at least 12 characters)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@nojv.local
SEED_ADMIN_PASSWORD=password123
# OAuth
GITHUB_CLIENT_ID=placeholder
GITHUB_CLIENT_SECRET=placeholder
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# Email (SMTP). Leave SMTP_HOST/SMTP_USER empty for a no-op mailer in local dev.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Redis
REDIS_URL=redis://localhost:6379

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
# Temporal Cloud / secured self-host HA (all optional; leave unset for local plaintext):
#   API-key auth (Temporal Cloud): set TEMPORAL_API_KEY (implies TLS), address = <ns>.<acct>.tmprl.cloud:7233
# TEMPORAL_API_KEY=
#   mTLS auth (Temporal Cloud classic / secured self-host): point at PEM files
# TEMPORAL_CLIENT_CERT_PATH=/etc/temporal/tls/client.pem
# TEMPORAL_CLIENT_KEY_PATH=/etc/temporal/tls/client.key
# TEMPORAL_SERVER_NAME=
#   Force TLS without client certs (server-TLS only):
# TEMPORAL_TLS=true

# Execution
EXECUTION_BACKEND=docker
# Comma-separated registry hosts accepted for special_env image refs. Default trusts the
# major public registries: ghcr.io,docker.io,quay.io,registry.gitlab.com,gcr.io,public.ecr.aws,mcr.microsoft.com,registry.k8s.io
# ADVANCED_IMAGE_ALLOWED_REGISTRIES=ghcr.io,docker.io
SANDBOX_IMAGE=nojv-sandbox:local
SANDBOX_CPU_LIMIT=1
SANDBOX_MEMORY_MB=256
SANDBOX_PIDS_LIMIT=64

# Worker
PORT=8080
WORKER_CONCURRENCY=4
# WORKER_MODE: "all" (default), "judge" (sandbox only), "platform" (lifecycle/plagiarism only)
WORKER_MODE=all
# Minutes a submission may stay pending/running before the platform sweeper marks
# it system_error and terminates its judge. Range 10–1440; defaults to 10.
SUBMISSION_PENDING_TIMEOUT_MINUTES=10

# Web (Vite)
# Comma-separated hostnames allowed by Vite host check.
# Example: localhost,127.0.0.1,your.domain
# Use "*" to allow all hosts (not recommended outside local debugging).
ALLOWED_HOSTS=localhost,127.0.0.1,your.domain

# SvelteKit adapter-node body-size cap (production only — Vite dev ignores it).
# Default 64 MiB so the 60 MB POST cap on bundle/workspace/checker/interactor
# upload routes is the effective ceiling. The adapter default is 512 KiB,
# which would silently reject every problem-asset upload.
BODY_SIZE_LIMIT=67108864

# Kubernetes — only if EXECUTION_BACKEND=kubernetes
# K8S_NAMESPACE=nojv-sandbox
# K8S_CPU_REQUEST=500m
# K8S_CPU_LIMIT=1
# K8S_MEMORY_REQUEST=256Mi
# K8S_MEMORY_LIMIT=512Mi

# Object Storage (S3-compatible — MinIO for local, GCS/R2/S3 for production)
# Local dev uses MinIO via docker-compose. `docker compose up -d minio minio-init`
# starts MinIO (S3 API on :9000, console on :9001) and auto-creates the `nojv`
# bucket. The credentials below match the docker-compose defaults.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=nojv
# S3_PUBLIC_URL=https://cdn.example.com

# Logging
# pino log level for apps/web + apps/worker. Optional — defaults to "info".
# Set "debug" for verbose local debugging.
LOG_LEVEL=info

# --- OpenTelemetry metrics export ---
# Standard OTLP push (consumed by apps/web + apps/worker on boot). Set the base
# URL; the apps append /v1/metrics. Leave empty to disable export (no-op SDK).
# For an in-cluster collector, point at its OTLP HTTP service (no headers needed).
# For Grafana Cloud, set OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic <base64(instanceId:token)>".
OTEL_EXPORTER_OTLP_ENDPOINT=
# Standard comma-separated key=value header list (e.g. auth). Empty = no headers.
OTEL_EXPORTER_OTLP_HEADERS=
# Dashboard provisioning (consumed by `pnpm grafana:provision` only)
GRAFANA_STACK_URL=
GRAFANA_SA_TOKEN=
# SLO alert-rule provisioning (optional; same script). When unset, the
# script provisions dashboards only and skips alert rules.
GRAFANA_ALERT_FOLDER_UID=
GRAFANA_PROM_DATASOURCE_UID=
# SLO alert destination (optional). When set, the script also provisions
# an email contact point + a notification policy routing alerts to it.
# WARNING: provisioning the policy replaces the stack's root policy.
GRAFANA_ALERT_EMAIL=
# Optional: separate per-app service name override
OTEL_SERVICE_NAME_WEB=nojv-web
OTEL_SERVICE_NAME_WORKER=nojv-worker
