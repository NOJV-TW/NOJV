    "integration/db/effective-time-window-migration.test.ts",
    "integration/db/effective-time-window-races.test.ts",
    "integration/db/lifecycle-schedule-identity-migration.test.ts",
    "integration/db/lifecycle-recovery.test.ts",
    "integration/db/lifecycle-cancellation-outbox.test.ts",
    "integration/db/durable-work-migration.test.ts",
    "integration/db/durable-work.test.ts",
    "integration/db/storage-pointer-migration.test.ts",
    "integration/db/storage-release-migration-history.test.ts",
    "integration/domain/announcement-publish-notification.test.ts",
    "integration/notification/notification-domain.test.ts",
    "integration/temporal/lifecycle-workflows.test.ts",
    "unit/domain/**/*.ts",
    "unit/core/**/*.ts",
    "unit/infra/env-manifest-parity.test.ts",
    "unit/infra/admin-elevation-cutover.test.ts",
    "unit/infra/image-impact.test.ts",
    "unit/infra/k8s-integration-target.test.ts",
    "unit/infra/migration-index-safety.test.ts",
    "unit/infra/release-gate.test.ts",
    "unit/infra/storage-release-cutover.test.ts",
    "unit/infra/supply-chain-policy.test.ts",
    "unit/infra/vitest-project-routing.test.ts",
    "unit/db/replay-constraints.test.ts",
    "unit/temporal/client.test.ts",
    "unit/temporal/durable-work-dispatch.test.ts",
    "unit/temporal/lifecycle-dispatch.test.ts",
    "unit/temporal/lifecycle-reconciliation.test.ts",
    "unit/temporal/submission-dispatch.test.ts",
    "unit/worker/durable-work-metrics.test.ts",
    "unit/worker/durable-work-registry.test.ts",
    "unit/worker/durable-work-workflow.test.ts",
    "unit/worker/durable-work.test.ts",
    "unit/worker/docker-container-sweep.test.ts",
    "unit/worker/docker-resource-sweeper.test.ts",
    "unit/worker/worker-app.test.ts",
    "setup/k8s-global-setup.ts",
    "setup/k8s-integration-target.ts"
