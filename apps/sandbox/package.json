{
  "name": "@nojv/sandbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "dev": "PORT=8082 node --env-file=../../.env --import tsx --watch src/index.ts",
    "lint": "eslint .",
    "start": "node --import tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nojv/domain": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nojv/config-eslint": "workspace:*",
    "@nojv/config-typescript": "workspace:*"
  }
}
