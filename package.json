{
  "name": "nojv",
  "description": "Production-oriented Online Judge platform monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "pnpm lint:application-queries && pnpm lint:retired-colors && pnpm lint:doc-drift && pnpm lint:migrations && pnpm lint:comments && pnpm lint:supply-chain && turbo lint",
    "lint:application-queries": "node scripts/check-query-returns.mjs",
    "lint:retired-colors": "node scripts/check-retired-colors.mjs",
    "lint:doc-drift": "node scripts/check-doc-drift.mjs",
    "lint:migrations": "node scripts/check-migrations.mjs",
    "lint:comments": "node scripts/check-comments.mjs",
    "lint:supply-chain": "node scripts/check-supply-chain-policy.mjs",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:integration": "vitest run --project integration",
    "test:integration:k8s": "vitest run --project k8s-integration",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:coverage": "vitest run --coverage --project unit --project integration",
    "test:db:provision": "node --import tsx tests/setup/provision-test-databases.ts",
    "test:all": "pnpm test:unit && pnpm test:component && pnpm test:integration && pnpm test:e2e",
    "typecheck": "turbo typecheck",
    "typecheck:tests": "tsc -p tests/tsconfig.json --noEmit && tsc -p tests/tsconfig.web.json --noEmit",
    "sandbox:build": "docker build -f infra/docker/sandbox-runner.Dockerfile -t nojv-sandbox:local .",
    "demo-advanced:build": "docker build -f infra/docker/demo-advanced-run/Dockerfile -t nojv-demo-advanced-run:local . && docker build -f infra/docker/demo-advanced-grade/Dockerfile -t nojv-demo-advanced-grade:local . && docker build -t nojv-demo-advanced-service:local apps/web/src/lib/server/advanced-scaffold/files/service",
    "demo-advanced:push": "scripts/publish-demo-images.sh",
    "grafana:provision": "node --env-file=.env --import tsx infra/grafana/provision.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "ci:verify": "pnpm format && pnpm lint:application-queries && pnpm lint:retired-colors && pnpm lint:doc-drift && pnpm lint:migrations && pnpm lint:comments && pnpm lint:supply-chain && turbo run build --concurrency=50% && turbo run typecheck --concurrency=50% && turbo run lint --concurrency=50% && pnpm typecheck:tests && pnpm test:unit && pnpm test:component",
    "db:deploy": "pnpm --filter @nojv/db db:deploy",
    "db:docs": "node scripts/generate-schema-docs.mjs",
    "db:generate": "pnpm --filter @nojv/db db:generate",
    "db:migrate": "pnpm --filter @nojv/db db:migrate",
    "db:push": "pnpm --filter @nojv/db db:push",
    "db:seed": "pnpm --filter @nojv/db db:seed",
    "db:seed:prod": "pnpm --filter @nojv/db db:seed:prod",
    "db:seed:validate": "pnpm --filter @nojv/db db:seed:validate",
    "db:validate": "pnpm --filter @nojv/db prisma:validate"
  },
  "devDependencies": {
    "@better-auth/core": "1.6.23",
    "@kubernetes/client-node": "^1.4.0",
    "@nojv/eslint-config": "workspace:*",
    "@nojv/prettier-config": "workspace:*",
    "@playwright/test": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@temporalio/activity": "catalog:",
    "@temporalio/client": "catalog:",
    "@temporalio/testing": "catalog:",
    "@temporalio/worker": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "29.1.1",
    "jszip": "catalog:",
    "prettier": "^3.9.5",
    "rate-limiter-flexible": "catalog:",
    "svelte": "^5.56.4",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "catalog:",
    "typescript-eslint": "^8.63.0",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
