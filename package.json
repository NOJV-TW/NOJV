{
  "name": "nojv",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "sandbox:build": "docker build -f infra/docker/sandbox-runner.Dockerfile -t nojv-sandbox:local .",
    "deploy:gcp": "bash infra/gcp/deploy.sh",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "ci:verify": "pnpm format && pnpm db:generate && pnpm lint && pnpm test && pnpm build && pnpm db:validate && docker compose config",
    "db:deploy": "pnpm --filter @nojv/db db:deploy",
    "db:generate": "pnpm --filter @nojv/db db:generate",
    "db:migrate": "pnpm --filter @nojv/db db:migrate",
    "db:push": "pnpm --filter @nojv/db db:push",
    "db:validate": "pnpm --filter @nojv/db prisma:validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.3.5",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
