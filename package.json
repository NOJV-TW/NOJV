{
  "name": "nojv",
  "description": "Production-oriented Online Judge platform monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "pnpm lint:domain-queries && turbo lint",
    "lint:domain-queries": "node tooling/scripts/check-query-returns.mjs",
    "test": "turbo test",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "typecheck": "turbo typecheck",
    "sandbox:build": "docker build -f infra/docker/sandbox-runner.Dockerfile -t nojv-sandbox:local .",
    "grafana:provision": "tsx infra/grafana/provision.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "ci:verify": "pnpm format && pnpm lint:domain-queries && pnpm db:generate && turbo run build typecheck lint test",
    "db:deploy": "pnpm --filter @nojv/db db:deploy",
    "db:generate": "pnpm --filter @nojv/db db:generate",
    "db:migrate": "pnpm --filter @nojv/db db:migrate",
    "db:push": "pnpm --filter @nojv/db db:push",
    "db:seed": "pnpm --filter @nojv/db db:seed",
    "db:seed:validate": "pnpm --filter @nojv/db db:seed:validate",
    "db:validate": "pnpm --filter @nojv/db prisma:validate"
  },
  "pnpm": {
    "overrides": {
      "@grpc/grpc-js": "~1.12.4",
      "vite": "^8.0.7",
      "solid-js": "^1.9.4",
      "drizzle-orm": "^0.45.2"
    },
    "onlyBuiltDependencies": [
      "@dodona/dolos-parsers",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "prisma",
      "tree-sitter",
      "tree-sitter-compat"
    ],
    "patchedDependencies": {
      "tree-sitter@0.25.0": "patches/tree-sitter@0.25.0.patch",
      "@dodona/dolos-parsers@1.4.1": "patches/@dodona__dolos-parsers@1.4.1.patch"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nojv/eslint-config": "workspace:*",
    "@nojv/prettier-config": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jszip": "^3.10.1",
    "prettier": "^3.8.1",
    "rate-limiter-flexible": "^11.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3",
    "zod": "^4.3.6"
  }
}
