{
  "name": "nojv",
  "description": "Production-oriented Online Judge platform monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "pnpm lint:domain-queries && turbo lint",
    "lint:domain-queries": "node scripts/check-query-returns.mjs",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "typecheck": "turbo typecheck",
    "sandbox:build": "docker build -f infra/docker/sandbox-runner.Dockerfile -t nojv-sandbox:local .",
    "demo-judge:build": "docker build -t nojv-demo-judge-shell:local infra/docker/demo-judge-shell",
    "grafana:provision": "node --env-file=.env --import tsx infra/grafana/provision.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "ci:verify": "pnpm format && pnpm lint:domain-queries && pnpm db:generate && turbo run build typecheck lint && pnpm test:unit",
    "db:deploy": "pnpm --filter @nojv/db db:deploy",
    "db:docs": "node scripts/generate-schema-docs.mjs",
    "db:generate": "pnpm --filter @nojv/db db:generate",
    "db:migrate": "pnpm --filter @nojv/db db:migrate",
    "db:push": "pnpm --filter @nojv/db db:push",
    "db:seed": "pnpm --filter @nojv/db db:seed",
    "db:seed:validate": "pnpm --filter @nojv/db db:seed:validate",
    "db:validate": "pnpm --filter @nojv/db prisma:validate"
  },
  "pnpm": {
    "overrides": {
      "kysely": "0.28.17",
      "protobufjs": "7.6.0",
      "monaco-editor>dompurify": "^3.4.9",
      "@prisma/dev>@hono/node-server": "^1.19.13"
    },
    "onlyBuiltDependencies": [
      "@dodona/dolos-parsers",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "prisma",
      "tree-sitter",
      "tree-sitter-compat"
    ],
    "patchedDependencies": {
      "tree-sitter@0.25.0": "patches/tree-sitter@0.25.0.patch",
      "@dodona/dolos-parsers@1.4.1": "patches/@dodona__dolos-parsers@1.4.1.patch"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nojv/eslint-config": "workspace:*",
    "@nojv/prettier-config": "workspace:*",
    "@playwright/test": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jszip": "catalog:",
    "prettier": "^3.8.3",
    "rate-limiter-flexible": "catalog:",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "typescript-eslint": "^8.60.1",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
