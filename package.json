{
  "name": "nojv",
  "description": "Production-oriented Online Judge platform monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "typecheck": "turbo typecheck",
    "sandbox:build": "docker build -f infra/docker/sandbox-runner.Dockerfile -t nojv-sandbox:local .",
    "deploy:gcp": "bash infra/gcp/deploy.sh",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "ci:verify": "pnpm format && pnpm db:generate && turbo run build lint test",
    "db:deploy": "pnpm --filter @nojv/db db:deploy",
    "db:generate": "pnpm --filter @nojv/db db:generate",
    "db:migrate": "pnpm --filter @nojv/db db:migrate",
    "db:push": "pnpm --filter @nojv/db db:push",
    "db:seed": "pnpm --filter @nojv/db db:seed",
    "db:validate": "pnpm --filter @nojv/db prisma:validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nojv/eslint-config": "workspace:*",
    "@nojv/prettier-config": "workspace:*",
    "@types/node": "^25.3.5",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "@prisma/adapter-pg": "^7.4.2",
    "prettier": "^3.8.1",
    "rate-limiter-flexible": "^9.1.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
