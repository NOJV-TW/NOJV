generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum SupportedLanguage {
  c
  cpp
  go
  java
  javascript
  python
  rust
  typescript
}

enum SubmissionMode {
  practice
  contest
  assignment
}

enum SubmissionStatus {
  queued
  compiling
  running
  accepted
  wrong_answer
  time_limit_exceeded
  memory_limit_exceeded
  runtime_error
  compile_error
}

enum JudgeType {
  standard
  checker
  interactive
}

enum SubmissionType {
  function
  full_source
}

enum ContestVisibility {
  draft
  published
  archived
}

enum ContestScoringMode {
  icpc
  ioi
}

enum PlagiarismReportStatus {
  pending
  running
  completed
  failed
}

enum ContestParticipationStatus {
  registered
  active
  submitted
  disqualified
}

enum PlatformRole {
  admin
  teacher
  student
}

enum CourseRole {
  teacher
  ta
  student
}

enum CourseVisibility {
  invite_only
  listed
  archived
}

enum CourseMembershipStatus {
  active
  invited
  pending
  removed
}

enum CourseJoinMethod {
  qr_code
  join_code
  manual_invite
}

enum ProblemVisibility {
  public
  private
}

enum CourseAssessmentStatus {
  draft
  published
  archived
}

enum CourseAssessmentScoreboardMode {
  hidden
  live
  frozen
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  username             String?                @unique
  displayUsername      String?
  name                 String
  emailVerified        Boolean                @default(false)
  image                String?
  locale               String                 @default("zh-TW")
  platformRole         PlatformRole           @default(student)
  disabled             Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  sessions             Session[]
  accounts             Account[]
  submissions          Submission[]
  contestParticipations ContestParticipation[]
  authoredProblems     Problem[]              @relation("ProblemAuthor")
  ownedCourses         Course[]               @relation("CourseOwner")
  courseMemberships    CourseMembership[]     @relation("CourseMembershipUser")
  createdMemberships   CourseMembership[]     @relation("CourseMembershipCreator")
  createdJoinTokens    CourseJoinToken[]      @relation("CourseJoinTokenCreator")
  attachedCourseProblems CourseProblem[]      @relation("CourseProblemAttacher")
  createdCourseAssessments CourseAssessment[] @relation("CourseAssessmentCreator")
  createdContests    Contest[]          @relation("ContestCreator")
  triggeredPlagiarismReports PlagiarismReport[] @relation("PlagiarismReportTriggeredBy")
  stats                      UserStats?
  editorials                 Editorial[]
  assessmentParticipations   AssessmentParticipation[]
  ipViolationLogs            IpViolationLog[]
}

model Problem {
  id                  String                  @id @default(cuid())
  slug                String                  @unique
  defaultTitle        String
  summary             String                  @db.Text
  difficulty          String
  visibility          ProblemVisibility       @default(public)
  tags                String[]                @default([])
  authorId            String?
  timeLimitMs         Int
  memoryLimitMb       Int
  judgeType           JudgeType               @default(standard)
  submissionType      SubmissionType          @default(full_source)
  checkerScript       String?                 @db.Text
  interactorScript    String?                 @db.Text
  pipelineConfig      Json?
  scoringScript       String?                 @db.Text
  scoringLanguage     String?
  artifactPatterns    String[]                @default([])
  networkAccessConfig Json?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  statements          ProblemStatementI18n[]
  testcaseSets        TestcaseSet[]
  templates           ProblemTemplate[]
  submissions         Submission[]
  contestLinks        ContestProblem[]
  courseLinks         CourseProblem[]
  assessmentLinks     CourseAssessmentProblem[]
  author              User?                   @relation("ProblemAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  editorials          Editorial[]
}

model ProblemStatementI18n {
  id           String   @id @default(cuid())
  problemId    String
  locale       String
  title        String
  bodyMarkdown String   @db.Text
  inputFormat  String   @default("") @db.Text
  outputFormat String   @default("") @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  problem      Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, locale])
}

model TestcaseSet {
  id            String   @id @default(cuid())
  problemId     String
  name          String
  isHidden      Boolean  @default(true)
  weight        Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  problem       Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  testcases     Testcase[]

  @@unique([problemId, name])
}

model Testcase {
  id             String      @id @default(cuid())
  testcaseSetId  String
  ordinal        Int
  stdin          String      @db.Text
  expectedStdout String?     @db.Text
  inputFiles     Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  testcaseSet    TestcaseSet @relation(fields: [testcaseSetId], references: [id], onDelete: Cascade)

  @@unique([testcaseSetId, ordinal])
}

model ProblemTemplate {
  id              String            @id @default(cuid())
  problemId       String
  language        SupportedLanguage
  driverCode      String            @db.Text
  templateCode    String            @db.Text
  insertionMarker String            @default("// __USER_CODE__")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  problem         Problem           @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, language])
}

model Contest {
  id                String                        @id @default(cuid())
  slug              String                        @unique
  title             String
  summary           String                        @db.Text
  startsAt          DateTime
  endsAt            DateTime
  frozenBoard       Boolean                       @default(true)
  visibility        ContestVisibility             @default(draft)
  scoringMode       ContestScoringMode            @default(icpc)
  courseId          String?
  frozenAt          DateTime?
  submitCooldownSec Int                           @default(0)
  pageLockEnabled    Boolean                       @default(false)
  ipWhitelistEnabled Boolean                       @default(false)
  ipBindingEnabled   Boolean                       @default(false)
  ipWhitelist        String[]                      @default([])
  ipViolationMode    String                        @default("block")
  maxAttempts        Int?
  scoreboardMode     CourseAssessmentScoreboardMode @default(live)
  allowedLanguages   SupportedLanguage[]           @default([])
  inviteCode         String?                       @unique
  createdByUserId    String?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  course             Course?                       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdBy          User?                         @relation("ContestCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  problems           ContestProblem[]
  participations     ContestParticipation[]
  submissions        Submission[]
  plagiarismReports  PlagiarismReport[]
  ipViolationLogs    IpViolationLog[]              @relation("IpViolationContest")
}

model ContestProblem {
  id             String   @id @default(cuid())
  contestId      String
  problemId      String
  ordinal        Int
  points         Int      @default(100)
  createdAt      DateTime @default(now())
  contest        Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([contestId, problemId])
  @@unique([contestId, ordinal])
}

model Course {
  id                String             @id @default(cuid())
  slug              String             @unique
  title             String
  description       String             @db.Text
  locale            String             @default("zh-TW")
  visibility        CourseVisibility   @default(invite_only)
  ownerId           String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  owner             User               @relation("CourseOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships       CourseMembership[]
  joinTokens        CourseJoinToken[]
  problems          CourseProblem[]
  assessments       CourseAssessment[]
  submissions       Submission[]
  contests          Contest[]
}

model CourseMembership {
  id            String                 @id @default(cuid())
  courseId      String
  userId        String
  role          CourseRole
  status        CourseMembershipStatus @default(active)
  joinedVia     CourseJoinMethod?
  addedByUserId String?
  joinedAt      DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  course        Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user          User                   @relation("CourseMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  addedBy       User?                  @relation("CourseMembershipCreator", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([courseId, userId])
  @@index([courseId, role, status])
  @@index([userId, status])
}

model CourseJoinToken {
  id              String           @id @default(cuid())
  courseId        String
  method          CourseJoinMethod
  token           String           @unique
  label           String
  createdByUserId String
  expiresAt       DateTime?
  maxUses         Int?
  usageCount      Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy       User             @relation("CourseJoinTokenCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([courseId, method])
}

model CourseProblem {
  id            String   @id @default(cuid())
  courseId      String
  problemId     String
  addedByUserId String
  createdAt     DateTime @default(now())
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  problem       Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  addedBy       User     @relation("CourseProblemAttacher", fields: [addedByUserId], references: [id], onDelete: Restrict)

  @@unique([courseId, problemId])
}

model CourseAssessment {
  id               String                         @id @default(cuid())
  courseId         String
  slug             String
  title            String
  summary          String                         @db.Text
  status           CourseAssessmentStatus         @default(draft)
  scoreboardMode   CourseAssessmentScoreboardMode @default(hidden)
  pageLockEnabled    Boolean                       @default(false)
  ipWhitelistEnabled Boolean                       @default(false)
  ipBindingEnabled   Boolean                       @default(false)
  ipWhitelist        String[]                      @default([])
  ipViolationMode    String                        @default("block")
  maxAttempts        Int?
  allowedLanguages   SupportedLanguage[]           @default([])
  opensAt            DateTime
  dueAt              DateTime
  closesAt           DateTime
  createdByUserId    String
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  course             Course                         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy          User                           @relation("CourseAssessmentCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  problems               CourseAssessmentProblem[]
  submissions            Submission[]
  plagiarismReports      PlagiarismReport[]
  assessmentParticipations AssessmentParticipation[]
  ipViolationLogs        IpViolationLog[]           @relation("IpViolationAssessment")

  @@unique([courseId, slug])
  @@index([courseId, status])
}

model CourseAssessmentProblem {
  id           String           @id @default(cuid())
  assessmentId String
  problemId    String
  ordinal      Int
  points       Int              @default(100)
  createdAt    DateTime         @default(now())
  assessment   CourseAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  problem      Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, problemId])
  @@unique([assessmentId, ordinal])
}

model ContestParticipation {
  id               String                       @id @default(cuid())
  contestId        String
  userId           String
  status           ContestParticipationStatus   @default(registered)
  startedAt        DateTime?
  submittedAt      DateTime?
  score            Int                          @default(0)
  penaltySeconds   Int                          @default(0)
  subtaskScores    Json?
  boundIp          String?
  boundAt          DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  contest          Contest                      @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user             User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions      Submission[]

  @@unique([contestId, userId])
}

model Submission {
  id                     String                @id @default(cuid())
  userId                 String
  problemId              String
  contestParticipationId String?
  contestId              String?
  courseId               String?
  courseAssessmentId     String?
  mode                   SubmissionMode
  sampleOnly             Boolean               @default(false)
  language               SupportedLanguage
  sourceCode             String                @db.Text
  status                 SubmissionStatus      @default(queued)
  score                  Int                   @default(0)
  runtimeMs              Int?
  memoryKb               Int?
  compilerOutput         String?               @db.Text
  verdictDetail          Json?
  subtaskResults         Json?
  pipelineResult         Json?
  artifactPaths          String[]              @default([])
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem                Problem               @relation(fields: [problemId], references: [id], onDelete: Cascade)
  contestParticipation   ContestParticipation? @relation(fields: [contestParticipationId], references: [id], onDelete: SetNull)
  contest                Contest?              @relation(fields: [contestId], references: [id], onDelete: SetNull)
  course                 Course?               @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseAssessment       CourseAssessment?     @relation(fields: [courseAssessmentId], references: [id], onDelete: SetNull)

  @@index([problemId, createdAt])
  @@index([userId, createdAt])
  @@index([courseId, courseAssessmentId, createdAt])
  @@index([contestParticipationId, problemId, createdAt])
  @@index([contestId, problemId, createdAt])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  pinned    Boolean  @default(false)
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlagiarismReport {
  id                  String                 @id @default(cuid())
  courseAssessmentId   String?
  contestId           String?
  triggeredById       String
  status              PlagiarismReportStatus @default(pending)
  results             Json?
  mossReportUrl       String?
  createdAt           DateTime               @default(now())
  completedAt         DateTime?
  courseAssessment     CourseAssessment?       @relation(fields: [courseAssessmentId], references: [id], onDelete: Cascade)
  contest             Contest?               @relation(fields: [contestId], references: [id], onDelete: Cascade)
  triggeredBy         User                   @relation("PlagiarismReportTriggeredBy", fields: [triggeredById], references: [id], onDelete: Cascade)
}

model UserStats {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalAc         Int      @default(0)
  totalAttempts   Int      @default(0)
  languageDist    Json     @default("{}")
  difficultyDist  Json     @default("{}")
  dailyActivity   Json     @default("[]")
  lastSubmittedAt DateTime?
  updatedAt       DateTime @updatedAt
}

model Editorial {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem           @relation(fields: [problemId], references: [id], onDelete: Cascade)
  content   String            @db.Text
  language  SupportedLanguage
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, problemId])
}

model AssessmentParticipation {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId String
  assessment   CourseAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  boundIp      String?
  boundAt      DateTime?
  createdAt    DateTime         @default(now())

  @@unique([userId, assessmentId])
}

model IpViolationLog {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  contestId     String?
  contest       Contest?         @relation("IpViolationContest", fields: [contestId], references: [id], onDelete: Cascade)
  assessmentId  String?
  assessment    CourseAssessment? @relation("IpViolationAssessment", fields: [assessmentId], references: [id], onDelete: Cascade)
  expectedIp    String?
  actualIp      String
  violationType String
  createdAt     DateTime         @default(now())
}
