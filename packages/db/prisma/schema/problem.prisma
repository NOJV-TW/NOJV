// ═══════════════════════════════════════════════════════════════
// Problem domain
// ═══════════════════════════════════════════════════════════════

enum ProblemVisibility {
  public
  private
}

enum ProblemStatus {
  draft
  published
}

/// Single source of truth for "what kind of problem is this".
/// Replaces the old (submissionType × mode) matrix.
enum ProblemType {
  full_source // Single-file submission with main()
  multi_file // Teacher ships scaffold (main + helpers); student edits in-browser
  special_env // TA Docker image owns the entire judging loop
}

enum ProblemImageSource {
  registry
  tarball
}

enum ProblemDifficulty {
  easy
  medium
  hard
}

enum WorkspaceFileVisibility {
  editable
  readonly
  hidden
}

enum SubtaskScoringStrategy {
  ALL_OR_NOTHING
  PROPORTIONAL
  MINIMUM
}

model Problem {
  id         String            @id @default(cuid())
  displayId  Int               @unique @default(autoincrement())
  title      String
  authorId   String?
  visibility ProblemVisibility @default(public)
  status     ProblemStatus     @default(draft)
  /// Dedicated column so the UI can colour-code difficulty without reading
  /// the free-form tag list.
  difficulty ProblemDifficulty @default(medium)
  /// Free-form tags (topics, skills). Difficulty lives in its own column —
  /// do NOT mirror it here.
  tags       String[]          @default([])
  /// Derived shape of the problem. See ProblemType.
  type       ProblemType       @default(full_source)

  /// Per-testcase limit for standard mode; total-per-invocation for
  /// special_env (the TA image runs all cases in one call).
  timeLimitMs   Int
  memoryLimitMb Int

  /// Judge config JSON: `{ type: "standard"|"checker"|"interactive", ... }`.
  /// Ignored when type = special_env (TA image decides everything).
  judgeConfig Json?
  /// Sample IO displayed in the problem statement (up to 5 entries).
  samples     Json?

  /// special_env only. Enforced at the app layer by a Zod .refine() on
  /// problemCreateSchema: type = 'special_env' iff both fields are set.
  advancedImageRef    String?
  advancedImageSource ProblemImageSource?

  /// special_env only. Each entry is a literal path; trailing "/" means
  /// "this folder must exist" (i.e. at least one uploaded file's path
  /// starts with this prefix). Validated by Zod refine: must be empty when
  /// type !== 'special_env'. See packages/core/src/schemas/required-paths.ts.
  advancedRequiredPaths String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  author             User?                  @relation("ProblemAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  statements         ProblemStatementI18n[]
  testcaseSets       TestcaseSet[]
  workspaceFiles     ProblemWorkspaceFile[]
  submissions        Submission[]
  contestLinks       ContestProblem[]
  examLinks          ExamProblem[]
  assessmentLinks    AssessmentProblem[]
  editorials         Editorial[]
  scoreOverrides     ScoreOverride[]        @relation("ScoreOverrideProblem")
  clarifications     Clarification[]        @relation("ProblemClarifications")
  submissionFeedback SubmissionFeedback[]   @relation("SubmissionFeedbackProblem")
  bookmarks          ProblemBookmark[]

  @@index([status, visibility, createdAt])
  @@index([authorId])
  @@index([difficulty])
  @@index([tags], type: Gin)
}

/// Per-user bookmark/favourite of a problem. Powers the "Bookmarked" filter
/// on the public library. Plain join row — no extra metadata.
model ProblemBookmark {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId, createdAt])
}

model ProblemStatementI18n {
  id           String   @id @default(cuid())
  problemId    String
  locale       String
  title        String
  bodyMarkdown String   @db.Text
  inputFormat  String   @default("") @db.Text
  outputFormat String   @default("") @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  problem      Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, locale])
}

model TestcaseSet {
  id              String                 @id @default(cuid())
  problemId       String
  name            String
  /// Describes the scope / constraints of this subset (e.g.
  /// "1 ≤ n ≤ 10^3, values distinct"). Shown to students on
  /// the problem page under the testcase section.
  description     String                 @default("") @db.Text
  weight          Int                    @default(1)
  /// Display order controlled by the teacher.
  ordinal         Int                    @default(0)
  /// How testcase results in this subtask are aggregated into a subtask score.
  scoringStrategy SubtaskScoringStrategy @default(ALL_OR_NOTHING)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  problem         Problem                @relation(fields: [problemId], references: [id], onDelete: Cascade)
  testcases       Testcase[]

  @@unique([problemId, name])
  @@unique([problemId, ordinal])
}

model Testcase {
  id            String      @id @default(cuid())
  testcaseSetId String
  ordinal       Int
  /// S3 object key for the input blob. Stable for the lifetime of the row;
  /// content is overwritten in place on edit. See packages/storage/src/keys.ts.
  inputKey      String
  /// S3 object key for the expected output blob. Null for problems that do
  /// not declare an expected output (e.g. interactive judges).
  outputKey     String?
  /// `{ filename: s3Key }` map for auxiliary input files that the program
  /// can read at judge time. Null when the testcase has no aux files.
  inputFileKeys Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  testcaseSet   TestcaseSet @relation(fields: [testcaseSetId], references: [id], onDelete: Cascade)

  @@unique([testcaseSetId, ordinal])
}

model ProblemWorkspaceFile {
  id          String                  @id @default(cuid())
  problemId   String
  language    SupportedLanguage
  path        String
  /// S3 object key for this workspace file's content. Stable for the lifetime
  /// of the row; content is overwritten in place on edit. See
  /// packages/storage/src/keys.ts.
  contentKey  String
  visibility  WorkspaceFileVisibility
  description String                  @default("") @db.Text
  orderIndex  Int                     @default(0)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  problem     Problem                 @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, language, path])
  @@index([problemId, language])
}
