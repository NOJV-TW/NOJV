{
  "name": "@nojv/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "pnpm db:generate && tsdown",
    "db:deploy": "prisma migrate deploy",
    "db:deploy:release": "sh prisma/scripts/deploy-release.sh",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node --env-file=../../.env --import tsx prisma/seed.ts",
    "db:bootstrap-admin": "node --env-file=../../.env --import tsx prisma/bootstrap-admin.ts",
    "db:seed:prod": "node --env-file=../../.env --import tsx prisma/prod-seed.ts",
    "db:seed:validate": "node --import tsx prisma/seeds/validate.ts",
    "storage:backfill": "node --import tsx prisma/scripts/storage-pointer-cutover.ts backfill",
    "storage:verify": "node --import tsx prisma/scripts/storage-pointer-cutover.ts verify",
    "storage:preflight": "node --import tsx prisma/scripts/storage-pointer-cutover.ts preflight",
    "storage:status": "node --import tsx prisma/scripts/storage-pointer-cutover.ts status",
    "lint": "eslint .",
    "prisma:validate": "prisma validate",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "node --env-file=../../.env --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nojv/core": "workspace:*",
    "@nojv/storage": "workspace:*",
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "bcryptjs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "prisma": "catalog:",
    "tsdown": "catalog:",
    "tsx": "^4.23.0"
  }
}
