{
  "name": "@nojv/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "pnpm db:generate && tsdown",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node --env-file=../../.env --import tsx prisma/seed.ts",
    "db:bootstrap-admin": "node --env-file=../../.env --import tsx prisma/bootstrap-admin.ts",
    "db:seed:validate": "node --import tsx prisma/seeds/validate.ts",
    "migrate:validator-scripts": "node --env-file=../../.env --import tsx prisma/scripts/migrate-validator-scripts-to-storage.ts",
    "backfill:participation": "node --env-file=../../.env --import tsx prisma/scripts/backfill-participation.ts",
    "reconcile:participation": "node --env-file=../../.env --import tsx prisma/scripts/reconcile-participation.ts",
    "lint": "eslint .",
    "prisma:validate": "prisma validate",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "node --env-file=../../.env --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nojv/core": "workspace:*",
    "@nojv/redis": "workspace:*",
    "@nojv/storage": "workspace:*",
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "bcryptjs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "prisma": "catalog:",
    "tsdown": "catalog:",
    "tsx": "^4.22.4"
  }
}
