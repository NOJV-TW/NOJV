{
  "name": "@nojv/temporal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./workflows": {
      "types": "./src/workflows/index.ts",
      "default": "./src/workflows/index.ts"
    },
    "./activities": {
      "types": "./src/activities/index.ts",
      "default": "./src/activities/index.ts"
    },
    "./activities/judge": {
      "types": "./src/activities/judge-bundle.ts",
      "default": "./src/activities/judge-bundle.ts"
    },
    "./activities/platform": {
      "types": "./src/activities/platform-bundle.ts",
      "default": "./src/activities/platform-bundle.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@temporalio/activity": "^1.11.7",
    "@temporalio/client": "^1.11.7",
    "@temporalio/common": "^1.11.7",
    "@temporalio/workflow": "^1.11.7",
    "@nojv/core": "workspace:*",
    "@nojv/domain": "workspace:*",
    "@nojv/redis": "workspace:*",
    "zod": "^4.3.6"
  }
